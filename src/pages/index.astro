---
import Layout from "../layouts/Layout.astro";
import resume from "../data/resume.json";

const { basics, available } = resume;
const location = `${basics.location.city}, ${basics.location.region}, ${basics.location.countryCode}`;
---

<Layout>
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col justify-center gap-10 px-6 py-20">
    {
      available && (
        <div class="inline-flex w-fit items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-sm font-medium text-emerald-700 dark:text-emerald-300">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75" />
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500" />
          </span>
          Open to opportunities
        </div>
      )
    }

    <header class="flex flex-col items-start gap-5 sm:flex-row sm:items-center sm:gap-6">
      {
        basics.image && (
          <img
            src={basics.image}
            alt={basics.name}
            width="96"
            height="96"
            loading="eager"
            decoding="async"
            class="h-20 w-20 shrink-0 rounded-full object-cover ring-2 ring-slate-200 dark:ring-slate-800 sm:h-24 sm:w-24"
          />
        )
      }
      <div class="flex flex-col gap-2">
        <h1 class="text-4xl font-bold tracking-tight text-balance sm:text-5xl">
          {basics.name}
        </h1>
        <p class="text-lg leading-snug text-balance text-slate-600 dark:text-slate-400">
          {basics.label}
        </p>
        <p class="text-sm text-slate-500 dark:text-slate-500">{location}</p>
      </div>
    </header>

    <p class="max-w-prose text-base leading-relaxed text-slate-700 text-justify hyphens-auto dark:text-slate-300">
      {basics.summary}
    </p>

    <nav class="flex flex-wrap gap-3">
      <a
        href="/resume"
        class="inline-flex items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-slate-700 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
      >
        Resume
      </a>
      <a
        href="/experience"
        class="inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-100 dark:hover:bg-slate-800"
      >
        Experience
      </a>
      <a
        href={`mailto:${basics.email}`}
        class="inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-100 dark:hover:bg-slate-800"
      >
        Contact
      </a>
    </nav>

    <footer class="flex flex-wrap items-center gap-x-3 gap-y-2 border-t border-slate-200 pt-6 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-500">
      {
        basics.profiles.map((profile, i) => (
          <>
            {i > 0 && (
              <span aria-hidden="true" class="text-slate-300 dark:text-slate-700">·</span>
            )}
            <a
              href={profile.url}
              class="transition hover:text-slate-900 dark:hover:text-slate-100"
            >
              {profile.network}
            </a>
          </>
        ))
      }
      <span aria-hidden="true" class="text-slate-300 dark:text-slate-700">·</span>
      <a
        href={`mailto:${basics.email}`}
        class="transition hover:text-slate-900 dark:hover:text-slate-100"
      >
        {basics.email}
      </a>
    </footer>
  </main>
</Layout>
