---
import Layout from "../layouts/Layout.astro";
import resume from "../data/resume.json";

const { basics, work } = resume;

const MONTHS = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

function formatMonthYear(date: string | null | undefined): string {
  if (!date) return "Present";
  const [yearStr, monthStr] = date.split("-");
  if (!monthStr) return yearStr;
  const month = parseInt(monthStr, 10);
  if (Number.isNaN(month) || month < 1 || month > 12) return yearStr;
  return `${MONTHS[month - 1]} ${yearStr}`;
}

function formatRange(start: string, end: string | null | undefined): string {
  return `${formatMonthYear(start)} – ${formatMonthYear(end)}`;
}

function monogramOf(name: string): string {
  return name.trim().charAt(0).toUpperCase();
}
---

<Layout title={`${basics.name} — Experience`}>
  <main class="mx-auto max-w-3xl px-6 py-12">
    <nav class="mb-6 text-sm text-slate-500 dark:text-slate-400">
      <a href="/" class="transition hover:text-slate-900 dark:hover:text-slate-100">← Home</a>
    </nav>

    <header>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Experience</h1>
      <p class="mt-2 text-base text-slate-600 dark:text-slate-400">
        Detailed work history — companies, projects, and the tech behind them.
      </p>
    </header>

    <div class="mt-10 space-y-10">
      {
        work.map((job) => {
          const monogram = monogramOf(job.name);
          return (
            <article class="flex flex-col gap-4 sm:flex-row sm:gap-5">
              <div class="relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-md bg-slate-100 text-base font-semibold text-slate-500 dark:bg-slate-800 dark:text-slate-400">
                <span aria-hidden="true">{monogram}</span>
                {job.logo && (
                  <img
                    src={job.logo}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    onerror="this.style.display='none'"
                    class="absolute inset-0 h-full w-full bg-white object-contain p-1"
                  />
                )}
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                  <h2 class="text-base font-semibold text-slate-900 dark:text-slate-100">
                    {job.url ? (
                      <a
                        href={job.url}
                        class="hover:underline hover:decoration-slate-400 hover:underline-offset-4"
                      >
                        {job.name}
                      </a>
                    ) : (
                      job.name
                    )}
                    {job.location && (
                      <span class="font-normal text-slate-600 dark:text-slate-400">
                        {" — "}
                        {job.location}
                      </span>
                    )}
                  </h2>
                  <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
                    {formatRange(job.startDate, job.endDate)}
                  </span>
                </div>
                <p class="mt-0.5 text-sm italic text-slate-700 dark:text-slate-300">{job.position}</p>

                {job.summary && (
                  <p class="mt-3 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                    {job.summary}
                  </p>
                )}

                {job.highlights && job.highlights.length > 0 && (
                  <ul class="mt-3 list-disc space-y-1 pl-5 text-sm leading-relaxed text-slate-700 marker:text-slate-400 dark:text-slate-300 dark:marker:text-slate-600">
                    {job.highlights.map((h) => <li>{h}</li>)}
                  </ul>
                )}

                {job.details && job.details.trim().length > 0 && (
                  <div class="mt-3 space-y-3 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                    {job.details.split(/\n\s*\n/).map((para) => <p>{para}</p>)}
                  </div>
                )}

                {job.projects && job.projects.length > 0 && (
                  <div class="mt-4">
                    <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                      Projects
                    </h3>
                    <ul class="mt-2 space-y-2">
                      {job.projects.map((p) => (
                        <li>
                          <div class="text-sm font-medium text-slate-900 dark:text-slate-100">
                            {p.url ? (
                              <a href={p.url} class="hover:underline hover:underline-offset-4">
                                {p.name}
                              </a>
                            ) : (
                              p.name
                            )}
                          </div>
                          {p.description && (
                            <p class="text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                              {p.description}
                            </p>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {job.stack && job.stack.length > 0 && (
                  <ul class="mt-4 flex flex-wrap gap-1.5">
                    {job.stack.map((tech) => (
                      <li class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                        {tech}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </main>
</Layout>
