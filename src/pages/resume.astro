---
import Layout from "../layouts/Layout.astro";
import resume from "../data/resume.json";

const { basics, work, education, skills, languages, publications } = resume;
const github = basics.profiles.find((p) => p.network === "GitHub");
const linkedin = basics.profiles.find((p) => p.network === "LinkedIn");
const location = `${basics.location.city}, ${basics.location.region}, ${basics.location.countryCode}`;

const MONTHS = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];

function formatMonthYear(date: string | null | undefined): string {
  if (!date) return "Present";
  const [yearStr, monthStr] = date.split("-");
  if (!monthStr) return yearStr;
  const month = parseInt(monthStr, 10);
  if (Number.isNaN(month) || month < 1 || month > 12) return yearStr;
  return `${MONTHS[month - 1]} ${yearStr}`;
}

function formatRange(start: string, end: string | null | undefined): string {
  return `${formatMonthYear(start)} – ${formatMonthYear(end)}`;
}

function hostnameOf(url: string): string {
  return url.replace(/^https?:\/\//, "").replace(/\/$/, "");
}
---

<Layout title={`${basics.name} — Resume`}>
  <main class="mx-auto max-w-3xl px-6 py-12 print:max-w-none print:px-0 print:py-0">
    <header class="flex flex-wrap items-start justify-between gap-x-6 gap-y-4">
      <div class="min-w-0">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{basics.name}</h1>
        <p class="mt-1 text-base text-slate-700 dark:text-slate-300">{basics.label}</p>
        <p class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-slate-600 dark:text-slate-400">
          <span>{location}</span>
          <span aria-hidden="true" class="text-slate-400 dark:text-slate-600">·</span>
          <a href={`mailto:${basics.email}`} class="hover:text-slate-900 dark:hover:text-slate-100">
            {basics.email}
          </a>
          {github?.url && (
            <>
              <span aria-hidden="true" class="text-slate-400 dark:text-slate-600">·</span>
              <a href={github.url} class="hover:text-slate-900 dark:hover:text-slate-100">GitHub</a>
            </>
          )}
          {linkedin?.url && (
            <>
              <span aria-hidden="true" class="text-slate-400 dark:text-slate-600">·</span>
              <a href={linkedin.url} class="hover:text-slate-900 dark:hover:text-slate-100">LinkedIn</a>
            </>
          )}
        </p>
      </div>
      <a
        href="/cv.pdf"
        class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800 print:hidden"
      >
        Download PDF
      </a>
    </header>

    <section class="mt-10">
      <h2 class="border-b border-slate-200 pb-1 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:border-slate-800 dark:text-slate-400">
        Professional summary
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
        {basics.summary}
      </p>
    </section>

    <section class="mt-8">
      <h2 class="border-b border-slate-200 pb-1 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:border-slate-800 dark:text-slate-400">
        Core competencies
      </h2>
      <dl class="mt-3 space-y-1.5 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
        {skills.map((skill) => (
          <div class="flex flex-wrap gap-x-2">
            <dt class="font-semibold text-slate-900 dark:text-slate-100">{skill.name}:</dt>
            <dd>{skill.keywords.join(", ")}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="mt-8">
      <h2 class="border-b border-slate-200 pb-1 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:border-slate-800 dark:text-slate-400">
        Experience
      </h2>
      <div class="mt-4 space-y-6">
        {work.map((job) => (
          <article class="break-inside-avoid">
            <div class="flex flex-wrap items-baseline justify-between gap-x-3">
              <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">
                {job.name}
                {job.location && (
                  <span class="font-normal text-slate-600 dark:text-slate-400">
                    {" — "}
                    {job.location}
                  </span>
                )}
              </h3>
              <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
                {formatRange(job.startDate, job.endDate)}
              </span>
            </div>
            <p class="mt-0.5 text-sm italic text-slate-700 dark:text-slate-300">{job.position}</p>
            {job.summary && (
              <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
                {job.summary}
              </p>
            )}
            {job.highlights && job.highlights.length > 0 && (
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-relaxed text-slate-700 marker:text-slate-400 dark:text-slate-300 dark:marker:text-slate-600">
                {job.highlights.map((h) => <li>{h}</li>)}
              </ul>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="mt-8">
      <h2 class="border-b border-slate-200 pb-1 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:border-slate-800 dark:text-slate-400">
        Education
      </h2>
      <div class="mt-3 space-y-3">
        {education.map((edu) => (
          <div class="flex flex-wrap items-baseline justify-between gap-x-3 text-sm">
            <div class="min-w-0">
              <p class="font-semibold text-slate-900 dark:text-slate-100">
                {edu.studyType}
                {edu.area && <span class="font-normal text-slate-700 dark:text-slate-300"> — {edu.area}</span>}
              </p>
              <p class="text-slate-700 dark:text-slate-300">{edu.institution}, {edu.location}</p>
            </div>
            <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
              {edu.startDate} – {edu.endDate}
            </span>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-8">
      <h2 class="border-b border-slate-200 pb-1 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:border-slate-800 dark:text-slate-400">
        Publications & open source
      </h2>
      <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
        {publications.map((pub) => (
          <li>
            <span>{pub.name}</span>
            {pub.url && (
              <>
                {" — "}
                <a
                  href={pub.url}
                  class="text-slate-900 underline decoration-slate-300 underline-offset-2 hover:decoration-slate-900 dark:text-slate-100 dark:decoration-slate-700 dark:hover:decoration-slate-100"
                >
                  {hostnameOf(pub.url)}
                </a>
              </>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="border-b border-slate-200 pb-1 text-xs font-semibold uppercase tracking-widest text-slate-500 dark:border-slate-800 dark:text-slate-400">
        Languages
      </h2>
      <p class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-700 dark:text-slate-300">
        {languages.map((l, i) => (
          <>
            {i > 0 && <span aria-hidden="true" class="text-slate-400 dark:text-slate-600">·</span>}
            <span>
              <span class="font-medium text-slate-900 dark:text-slate-100">{l.language}</span>{" "}
              <span class="text-slate-600 dark:text-slate-400">({l.fluency})</span>
            </span>
          </>
        ))}
      </p>
    </section>
  </main>
</Layout>
